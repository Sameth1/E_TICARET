@model Core.Concrates.DTOs.CustomerDTOs.FavoritesDTO
@{
    ViewData["Title"] = "My Favorites";
}

<div class="container py-5">
    <h2 class="mb-4">My Favorites</h2>

    @if (Model?.Items == null || Model.Items.Count == 0)
    {
        <div class="alert alert-info">
            Your favorites list is empty. <a asp-controller="Home" asp-action="Index">Start shopping</a>.
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model.Items)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 product-wap rounded-0">
                        <div class="card rounded-0 position-relative">
                            <img class="card-img rounded-0 img-fluid" src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/assets/img/placeholder.png" : item.ImageUrl)" alt="@item.ProductName" style="height: 200px; object-fit: cover;">
                            <div class="card-img-overlay d-flex align-items-center justify-content-center">
                                <div class="btn-group">
                                    <a asp-controller="Home" asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-success btn-sm text-white" title="View product">
                                        <i class="far fa-eye"></i>
                                    </a>
                                    <a asp-controller="Favorites" asp-action="AddToCart" asp-route-productId="@item.ProductId" asp-route-returnUrl="@Context.Request.Path" class="btn btn-primary btn-sm text-white" title="Add to cart">
                                        <i class="fas fa-shopping-cart"></i>
                                    </a>
                                    <a asp-controller="Favorites" asp-action="Remove" asp-route-productId="@item.ProductId" class="btn btn-danger btn-sm text-white" title="Remove from favorites">
                                        <i class="fas fa-heart-broken"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <a asp-controller="Home" asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none text-dark">
                                <h6 class="card-title">@item.ProductName</h6>
                            </a>
                            @if (item.DiscountedPrice < item.Price)
                            {
                                <p class="mb-0 text-muted small"><del>₺@item.Price.ToString("0.00")</del></p>
                                <p class="mb-0 text-success fw-bold">₺@item.DiscountedPrice.ToString("0.00")</p>
                            }
                            else
                            {
                                <p class="mb-0">₺@item.Price.ToString("0.00")</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
