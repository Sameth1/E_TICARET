@model Core.Concrates.DTOs.CustomerDTOs.CartDTO
@{
    ViewData["Title"] = "Checkout - Pay with Card";
}

<div class="container py-5">
    <h2 class="mb-4">Checkout</h2>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Order Summary</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.Items)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span>@item.ProductName x @item.Quantity</span>
                                <span>₺@((item.Price * item.Quantity).ToString("0.00"))</span>
                            </li>
                        }
                    </ul>
                    <hr />
                    <div class="d-flex justify-content-between">
                        <strong>Total:</strong>
                        <strong>₺@Model.TotalPrice.ToString("0.00")</strong>
                    </div>
                </div>
            </div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary mt-2">
                <i class="fas fa-arrow-left"></i> Continue Shopping
            </a>
        </div>

        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-credit-card me-2"></i>Pay with Card</h5>
                </div>
                <div class="card-body">
                    <form asp-controller="Cart" asp-action="PlaceOrder" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Cardholder Name</label>
                            <input type="text" class="form-control" name="cardHolderName" placeholder="Name on card" required maxlength="100" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Card Number</label>
                            <input type="text" class="form-control" name="cardNumber" placeholder="0000 0000 0000 0000" required maxlength="19" pattern="[\d\s]+" />
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Expiry (MM/YY)</label>
                                <input type="text" class="form-control" name="expiry" placeholder="MM/YY" required maxlength="5" />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">CVV</label>
                                <input type="text" class="form-control" name="cvv" placeholder="***" required maxlength="4" pattern="\d{3,4}" />
                            </div>
                        </div>
                        <hr />
                        <button type="submit" class="btn btn-success btn-lg w-100">
                            <i class="fas fa-lock me-2"></i>Complete Payment
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
