@model IReadOnlyList<Core.Concrates.DTOs.CustomerDTOs.OrderSummaryDTO>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container py-5">
    <h2 class="mb-4">My Orders</h2>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">
            You have no orders yet.
            <a asp-controller="Home" asp-action="Index">Start shopping</a>.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Order No</th>
                                <th>Date</th>
                                <th>Items</th>
                                <th class="text-end">Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td>#@order.Id</td>
                                    <td>@order.CreateDate.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@order.ItemsCount</td>
                                    <td class="text-end">₺@order.TotalDue.ToString("0.00")</td>
                                    <td>
                                        <a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Detail</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
